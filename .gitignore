# --- Python / Backend ---
backend/venv/
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.pytest_cache/
backend/.env

# --- Node.js (Bot & Frontend) ---
# Separating node_modules for both directories
backend/node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/

# --- WhatsApp Bot (CRITICAL) ---
# Prevents committing your personal WhatsApp session/auth data
backend/.wwebjs_auth/
backend/.wwebjs_cache/

# --- Environment & Secrets ---
# Keep all secret files out of Git for security
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env*

# --- Playwright / Browser Binaries ---
# Prevents committing large browser executables if installed locally
ms-playwright/
.cache/ms-playwright/

# --- System / IDE / Logs ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log
npm-debug.log*
yarn-debug.log*

# --- Database ---
*.sqlite3